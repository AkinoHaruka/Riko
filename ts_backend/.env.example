# 服务端口
PORT=3000

# 服务绑定地址（默认 127.0.0.1 仅本地访问，Docker/网络部署请改为 0.0.0.0）
HOST=127.0.0.1

# JWT 密钥（生产环境必须修改为随机强密码）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# DeepSeek API 密钥
DEEPSEEK_API_KEY=your-deepseek-api-key

# 数据库文件路径
DB_PATH=./data/app.db

# 数据库引擎（留空自动选择 better-sqlite3，设为 wasm 强制使用 sql.js）
# DB_ENGINE=

# 加密密钥（32 字节十六进制字符串，生产环境请使用随机生成的密钥）
ENCRYPTION_KEY=generate-a-32-byte-hex-key-for-production

# CORS 允许的来源域名（逗号分隔，留空默认仅允许 localhost:3000）
ALLOWED_ORIGINS=

# 认证严格模式（true=强制 JWT 验证/多用户模式；默认关闭=自动创建默认用户/单用户桌面模式）
# 多用户部署时务必设为 true，否则所有请求将以默认用户身份执行
AUTH_STRICT_MODE=false

# 记忆文件根目录
MEMORY_ROOT_DIR=./data/memories

# System Prompts 根目录
SYSTEM_PROMPTS_DIR=./data/prompts

# 日志级别（DEBUG/INFO/WARN/ERROR）
LOG_LEVEL=INFO

# 梦境功能配置
DREAM_ENABLED=true
DREAM_MIN_HOURS=24
DREAM_MIN_SESSIONS=5
# DREAM_MODEL=deepseek-v4-pro
# DREAM_TEMPERATURE=0.3
# DREAM_TRANSCRIPT_DIR=
